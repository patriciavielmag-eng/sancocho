const plans = [
	{
		price: 100,
		features: ["Logotipo", "Paleta de color", "Tipografía"],
		bg: "bg-brand-orange text-white",
	},
	{
		price: 200,
		features: ["Branding Completo", "Papelería", "Redes Sociales"],
		bg: "bg-white text-zinc-900",
