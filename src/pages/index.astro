			>
				<div class="w-[80%] mx-auto">
					<div class="flex justify-center items-center mb-12 gap-8">
						<span class="text-4xl text-brand-black">
							<svg
								width="40"
								height="40"
								viewBox="0 0 100 100"
								class="fill-current"
							>
								<path
									d="M50 0 L55 40 L95 15 L60 45 L100 50 L60 55 L95 85 L55 60 L50 100 L45 60 L5 85 L40 55 L0 50 L40 45 L5 15 L45 40 Z"
								></path>
							</svg>
						</span>
						<h2
							class="text-8xl md:text-9xl font-display uppercase tracking-tighter text-brand-black"
						>
							EL MENÚ
						</h2>
						<span class="text-4xl text-brand-black">
							<svg
								width="40"
								height="40"
								viewBox="0 0 100 100"
								class="fill-current"
							>
								<path
									d="M50 0 L55 40 L95 15 L60 45 L100 50 L60 55 L95 85 L55 60 L50 100 L45 60 L5 85 L40 55 L0 50 L40 45 L5 15 L45 40 Z"
								></path>
							</svg>
						</span>
					</div>
					<p
						class="text-center font-mono text-sm mb-12 uppercase tracking-widest text-brand-black opacity-60"
					>
