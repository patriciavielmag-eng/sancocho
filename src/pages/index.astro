							Contacto
						</a>
					</div>

					<div
						class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[400px]"
					>
						{/* Card 1: Branding */}
						<div
							class="bg-menu-1 rounded-4xl p-6 relative group overflow-hidden flex items-center justify-center"
						>
							<div
								class="w-[80%] h-[70%] bg-white rounded-2xl p-6 shadow-sm relative group-hover:scale-105 transition-transform duration-500 mb-8 border border-black/5"
							>
								<div class="flex gap-2 mb-6">
									<div
										class="h-6 w-1/3 bg-blue-600 rounded-md"
									>
									</div>
									<div
										class="h-6 w-1/4 bg-brand-orange rounded-md"
									>
									</div>
									<div
										class="h-6 w-1/4 bg-brand-black rounded-md"
									>
									</div>
								</div>
								<h3
									class="font-display text-5xl text-blue-600 leading-none mb-3"
								>
									Font
								</h3>
								<p
									class="text-xs font-sans font-bold uppercase text-brand-black tracking-widest"
								>
									Brand Guidelines
								</p>
								<div
									class="absolute bottom-12 right-6 rotate-12 text-7xl font-display text-menu-5 opacity-60"
								>
									a
								</div>
								<div
									class="absolute bottom-6 left-6 h-6 w-2/3 bg-menu-2 rounded-md"
								>
								</div>
							</div>
							<div
								class="absolute bottom-6 inset-x-0 mx-auto flex justify-center w-full"
							>
								<span
									class="bg-white text-brand-black px-8 py-3 rounded-[32px] text-sm font-sans font-bold shadow-sm"
