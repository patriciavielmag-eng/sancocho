			<!-- Portfolio Section -->
			<section
				data-theme="dark"
				class="min-h-screen w-full flex flex-col justify-center bg-brand-black text-white px-4 py-24 overflow-hidden"
			>
				<div class="w-[90%] md:w-[80%] mx-auto">
