---

<Layout title="Sancocho | Studio Creativo">
	<main
		class="h-screen w-full overflow-hidden relative bg-brand-cream text-brand-black"
	>
		<div
			id="scroll-container"
			class="h-full w-full transition-transform duration-1000 ease-in-out"
		>
			<!-- Hero Section -->
			<section
				class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-brand-cream"
			>
				<!-- 8-point stars (snowflake style) -->
				<div
					class="absolute top-20 left-10 md:top-32 md:left-20 text-brand-orange animate-pulse"
				>
					<svg
						width="80"
						height="80"
						viewBox="0 0 100 100"
						class="fill-current"
					>
						<path
							d="M50 0 L55 40 L95 15 L60 45 L100 50 L60 55 L95 85 L55 60 L50 100 L45 60 L5 85 L40 55 L0 50 L40 45 L5 15 L45 40 Z"
						></path>
					</svg>
				</div>
				<div
					class="absolute bottom-20 right-10 md:bottom-32 md:right-20 text-brand-orange animate-pulse"
				>
					<svg
						width="80"
						height="80"
						viewBox="0 0 100 100"
						class="fill-current"
					>
						<path
							d="M50 0 L55 40 L95 15 L60 45 L100 50 L60 55 L95 85 L55 60 L50 100 L45 60 L5 85 L40 55 L0 50 L40 45 L5 15 L45 40 Z"
						></path>
					</svg>
				</div>

				<div class="relative z-10 flex flex-col items-center">
					<div
						class="text-center font-display leading-[0.8] tracking-tighter"
					>
						<div
							class="text-[18vw] md:text-[14vw] flex items-center justify-center"
						>
							<span class="mr-[-2vw]">-Studio</span>
						</div>
						<div
							class="text-[22vw] md:text-[18vw] flex items-center justify-center -mt-[2vw] relative"
						>
							<span>Cre</span>
							<!-- Placeholder for Yolk -->
							<div
								class="mx-[1vw] w-[14vw] h-[14vw] bg-brand-orange rounded-full flex items-center justify-center overflow-hidden relative"
							>
								<div
									class="absolute inset-0 bg-gradient-to-tr from-brand-orange to-yellow-300 opacity-80"
								>
								</div>
								<div
									class="w-[60%] h-[60%] bg-white rounded-full opacity-40 blur-sm"
								>
								</div>
							</div>
							<span>tivo</span>
						</div>
					</div>

					<div class="mt-8 text-center">
						<p
							class="text-[3vw] md:text-[1.5vw] font-inter uppercase tracking-[0.3em] text-brand-black"
						>
							con mucho
						</p>
						<h2
							class="text-[12vw] md:text-[8vw] font-display -mt-[2vw]"
						>
							sabor
						</h2>
					</div>
				</div>

				<!-- Navigation circles context (from image) -->
				<div
					class="absolute right-10 top-1/2 -translate-y-1/2 flex flex-col gap-4 opacity-30"
				>
					<div class="w-3 h-3 rounded-full border border-brand-black">
					</div>
					<div class="w-3 h-3 rounded-full border border-brand-black">
					</div>
					<div class="w-3 h-3 rounded-full bg-brand-black"></div>
				</div>
			</section>

			<!-- Menu Section -->
			<section
				class="h-screen w-full flex flex-col justify-center px-4"
