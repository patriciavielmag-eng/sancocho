								>
							</div>
						</div>

						{/* Card 2: Web */}
						<div
							class="bg-menu-3 rounded-4xl p-6 relative group overflow-hidden"
						>
							<div
								class="absolute inset-0 group-hover:scale-110 transition-transform duration-500"
							>
								<div
									class="absolute top-1/4 left-1/4 w-32 h-32 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-pulse"
								>
								</div>
								<div
									class="absolute top-1/3 right-1/4 w-40 h-40 bg-purple-400 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-pulse delay-75"
								>
								</div>
								<div
									class="absolute bottom-1/4 left-1/3 w-36 h-36 bg-pink-400 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-pulse delay-150"
								>
								</div>
							</div>
							<div
								class="absolute bottom-6 inset-x-0 mx-auto flex justify-center w-full"
							>
