			</section>

			<!-- Team Section -->
			<section class="h-screen w-full flex flex-col justify-center px-4">
				<div class="w-[80%] mx-auto">
					<div class="flex flex-col items-center mb-16 relative">
						<div class="absolute -top-10 text-brand-orange">
							<svg
								width="40"
								height="40"
								viewBox="0 0 100 100"
