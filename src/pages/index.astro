							class="text-6xl md:text-[10vw] font-display mb-4 text-center tracking-tighter text-brand-black"
						>
							El Mix Team
						</h2>
						<div class="text-brand-orange">
							<svg
								width="30"
								height="30"
								viewBox="0 0 100 100"
								class="fill-current"
