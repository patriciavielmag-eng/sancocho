	},
	{
		id: 2,
		title: "3D & Motion",
		bg: "bg-menu-2",
		text: "text-zinc-900",
		link: import.meta.env.BASE_URL + "servicios/#3d",
	},
	{
		id: 3,
		title: "Web Plans",
		bg: "bg-menu-3",
		text: "text-zinc-900",
		link: import.meta.env.BASE_URL + "servicios/#web",
	},
	{
		id: 4,
		title: "Creación\nde Content",
		bg: "bg-menu-4",
		text: "text-zinc-900",
		link: import.meta.env.BASE_URL + "servicios/#content",
