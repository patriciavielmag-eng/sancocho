							services.map((service, index) => {
								let gridClasses =
									"group flex flex-col justify-between p-10 rounded-4xl transition-all duration-500 hover:scale-[1.02] relative overflow-hidden ";

								return (
									<a
										href={service.link}
										class={`${gridClasses} ${service.bg} ${service.text}`}
									>
										<div class="flex items-center justify-between w-full relative z-10">
											<span class="flex items-center justify-center w-10 h-10 rounded-full bg-brand-black text-white text-sm font-bold">
												{service.id}
											</span>
											<div class="transform group-hover:translate-x-2 transition-transform duration-300">
												<svg
													xmlns="http://www.w3.org/2000/svg"
													class="h-8 w-8"
													fill="none"
													viewBox="0 0 24 24"
													stroke="currentColor"
